# ═══════════════════════════════════════════════════════════
# ПУЛЬТ — Backend Environment Template
# Copy to .env and fill in real values. Never commit .env.
# ═══════════════════════════════════════════════════════════

# ── App ──────────────────────────────────────────────────────────────────────
APP_ENV=development
# Values: development | production

# ── Security ─────────────────────────────────────────────────────────────────
SECRET_KEY=change_me_use_openssl_rand_hex_32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── Database ─────────────────────────────────────────────────────────────────
# Development (SQLite):
DATABASE_URL=sqlite+aiosqlite:///./business_pult.db
# Production (PostgreSQL):
# DATABASE_URL=postgresql+asyncpg://user:password@host:5432/business_pult

# ── URLs ─────────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
API_URL=http://localhost:8000
# Production examples:
# FRONTEND_URL=https://pult.yourdomain.com
# API_URL=https://api.yourdomain.com

# ── Telegram Bot ─────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=

# ── VK ───────────────────────────────────────────────────────────────────────
VK_API_TOKEN=

# ── Supplier Verification APIs ───────────────────────────────────────────────
DGIS_API_KEY=
FNS_API_KEY=

# ── Nano Banana AI (image generation) ────────────────────────────────────────
NANO_BANANA_API_KEY=

# ── YooKassa (payments) ───────────────────────────────────────────────────────
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
# Leave empty to auto-derive from FRONTEND_URL + /payment/result
YOOKASSA_RETURN_URL=

# ── Redis (optional, reserved for future queue) ───────────────────────────────
REDIS_URL=redis://localhost:6379
